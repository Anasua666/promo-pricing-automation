# AWS / Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Database (plug in your real pricing DB)
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/pricing

# Filesystem paths mirroring the current manual folder structure
SUBMISSIONS_ROOT=./data/submissions
FISCAL_CALENDAR_XLSX=./data/inputs/fiscal_calendar.xlsx
PRICE_FILE_XLSX=./data/inputs/price_file.xlsx

# Email (merchant notification on reject)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=pricing-automation@example.com
